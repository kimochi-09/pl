<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>🎣 Fishing World: Chat & Chill</title>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
<style>
  :root{
    --bg-deep:#04263f;
    --bg-mid:#0a4a72;
    --bg-light:#1980b8;
    --gold:#ffd35c;
    --gold-dark:#e0a900;
    --panel:#0e2f4a;
    --panel-light:#123a5c;
    --text:#eaf6ff;
    --text-dim:#9fc4de;
    --common:#b9c7d3;
    --uncommon:#3ddc84;
    --rare:#4fb3ff;
    --epic:#c163ff;
    --mythic:#ff7a45;
    --nav-h:58px;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent; user-select:none;}
  html,body{
    margin:0; padding:0; height:100%; width:100%;
    font-family:'Segoe UI',system-ui,-apple-system,sans-serif;
    background:linear-gradient(180deg,#0d3a5c 0%, var(--bg-deep) 60%, #021625 100%);
    color:var(--text);
    overflow:hidden;
    touch-action:manipulation;
  }
  #app{position:relative; width:100%; height:100%; max-width:520px; margin:0 auto; display:flex; flex-direction:column; overflow:hidden; box-shadow:0 0 40px rgba(0,0,0,.5);}

  /* DESKTOP: kéo rộng vừa màn hình máy tính thay vì thu nhỏ dạng khung điện thoại */
  @media (min-width:701px){
    #app{
      max-width:1100px;
      border-radius:0;
      box-shadow:none;
    }
  }

  /* HEADER */
  #header{
    display:flex; align-items:center; justify-content:space-between;
    padding:8px 10px; background:rgba(2,20,34,.85); backdrop-filter:blur(4px);
    border-bottom:1px solid rgba(255,255,255,.08); z-index:20; flex-shrink:0;
  }
  #header .stat{display:flex; align-items:center; gap:4px; font-weight:700; font-size:14px; background:rgba(255,255,255,.06); padding:5px 9px; border-radius:20px;}
  #soundToggleBtn{border:none; font-size:15px; padding:5px 9px; line-height:1;}
  #header .stat .ic{font-size:15px;}
  #playerName{font-size:12px; color:var(--text-dim); font-weight:600;}

  /* ACCOUNT BUTTON */
  #accountBtn{
    display:flex; align-items:center; gap:6px; background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.1); border-radius:20px; padding:5px 10px 5px 5px;
    color:var(--text); font-size:11.5px; font-weight:700;
  }
  #accountBtn .avatarIc{
    width:24px; height:24px; border-radius:50%; background:var(--gold); color:#3a2400;
    display:flex; align-items:center; justify-content:center; font-size:13px; flex-shrink:0;
    overflow:hidden;
  }
  #accountBtn.loggedIn .avatarIc{background:var(--uncommon); color:#04351f;}

  /* AUTH MODAL */
  #authModalWrap{
    position:absolute; inset:0; background:rgba(2,10,18,.75); z-index:90;
    display:none; align-items:center; justify-content:center; padding:20px;
  }
  #authModalWrap.show{display:flex;}
  #authModal{
    background:var(--panel); border-radius:18px; padding:22px 20px; width:100%; max-width:340px;
    border:1px solid rgba(255,255,255,.08); box-shadow:0 12px 40px rgba(0,0,0,.5);
  }
  #authModal h3{margin:0 0 4px; font-size:19px; font-weight:800;}
  #authModal .authSub{font-size:12.5px; color:var(--text-dim); margin-bottom:16px;}
  #authModal input{
    width:100%; background:var(--bg-deep); border:1px solid rgba(255,255,255,.12); border-radius:10px;
    padding:12px 14px; color:var(--text); font-size:14px; margin-bottom:10px; outline:none;
  }
  #authModal input:focus{border-color:var(--gold);}
  #authModal .authBtn{
    width:100%; background:linear-gradient(180deg,#ffe08a,var(--gold-dark)); color:#3a2400; border:none;
    border-radius:10px; padding:13px; font-weight:800; font-size:14.5px; margin-top:4px; box-shadow:0 4px 0 #9e6f00;
  }
  #authModal .authBtn:disabled{opacity:.6;}
  #authSwitch{text-align:center; font-size:12.5px; color:var(--text-dim); margin-top:14px;}
  #authSwitch a{color:var(--gold); font-weight:700; text-decoration:none;}
  #authError{color:#ff6b6b; font-size:12px; margin-top:2px; margin-bottom:6px; min-height:14px;}
  #authClose{
    position:absolute; top:14px; right:14px; background:rgba(255,255,255,.08); border:none;
    width:30px; height:30px; border-radius:50%; color:var(--text); font-size:15px;
  }
  #authModal{position:relative;}
  #accountPanelBody{padding-top:6px;}
  .accInfoRow{display:flex; justify-content:space-between; padding:12px 4px; border-bottom:1px solid rgba(255,255,255,.06); font-size:13.5px;}
  .accInfoRow span:first-child{color:var(--text-dim);}
  .logoutBtn{
    width:100%; background:rgba(255,107,107,.15); color:#ff8a8a; border:1px solid rgba(255,107,107,.3);
    border-radius:12px; padding:13px; font-weight:800; font-size:14px; margin-top:20px;
  }

  /* AVATAR PICKER */
  #accAvatarBig{
    width:72px; height:72px; border-radius:50%; background:var(--gold); color:#3a2400; font-size:32px;
    display:flex; align-items:center; justify-content:center; margin:0 auto 8px; position:relative;
    border:none; overflow:hidden; padding:0; box-sizing:border-box; -webkit-appearance:none; appearance:none;
  }
  #accAvatarBig img{display:block;}
  .nameRow{display:flex; align-items:center; justify-content:center; gap:6px;}
  .nameEditBtn{
    background:rgba(255,255,255,.08); border:none; color:var(--text-dim); font-size:12px;
    width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .nameEditRow{display:flex; align-items:center; justify-content:center; gap:6px; margin-top:4px;}
  .nameEditRow input{
    background:var(--bg-deep); border:1px solid rgba(255,255,255,.15); border-radius:8px; color:var(--text);
    padding:7px 10px; font-size:13.5px; width:150px; text-align:center;
  }
  .nameEditRow button{
    border:none; border-radius:8px; padding:7px 10px; font-weight:700; font-size:12.5px;
  }
  .nameEditRow .nameSaveBtn{background:var(--gold); color:#3a2400;}
  .nameEditRow .nameCancelBtn{background:rgba(255,255,255,.08); color:var(--text);}
  #accAvatarBig .editBadge{
    position:absolute; bottom:-2px; right:-2px; width:24px; height:24px; border-radius:50%;
    background:var(--panel); border:2px solid var(--bg-deep); font-size:12px;
    display:flex; align-items:center; justify-content:center;
  }
  .uploadAvatarBtn{
    display:block; background:linear-gradient(180deg,#ffe08a,var(--gold-dark)); color:#3a2400; border:none;
    border-radius:12px; padding:12px; font-weight:800; font-size:13px; box-shadow:0 4px 0 #9e6f00;
  }

  /* MAIN GAME AREA */
  #gameArea{
    position:relative; flex:1; overflow:hidden;
    background:linear-gradient(180deg,#1c6ea3 0%, #0f4f7f 40%, #072f4d 100%);
  }
  .bubble{position:absolute; bottom:-20px; border-radius:50%; background:rgba(255,255,255,.15); animation:rise linear infinite;}
  @keyframes rise{ to{ transform:translateY(-120vh); opacity:0;} }

  #waterLine{position:absolute; top:0; left:0; right:0; height:6px; background:linear-gradient(90deg,#2fa9e0,#1980b8,#2fa9e0); opacity:.6;}

  #rodArea{
    position:absolute; top:20px; left:50%; transform:translateX(-50%);
    text-align:center; z-index:5;
  }
  #rodIcon{font-size:34px; filter:drop-shadow(0 3px 6px rgba(0,0,0,.4));}
  #line{
    position:absolute; left:50%; top:50px; width:2px; background:rgba(255,255,255,.5);
    transform:translateX(-50%); transition:height .3s;
  }
  #hook{
    position:absolute; left:50%; transform:translateX(-50%); font-size:20px;
    transition:top .4s ease-in-out;
  }

  #catchZone{
    position:absolute; left:50%; top:55%; transform:translate(-50%,-50%);
    display:flex; flex-direction:column; align-items:center; gap:14px; z-index:10;
  }
  #fishSilhouette{font-size:60px; animation:wiggle .4s infinite alternate;}
  @keyframes wiggle{ from{transform:rotate(-8deg);} to{transform:rotate(8deg);} }

  #statusText{
    text-align:center; font-size:15px; font-weight:700; color:var(--gold);
    text-shadow:0 2px 6px rgba(0,0,0,.5); margin-top:6px; min-height:20px;
  }

  #castBtn{
    position:absolute; bottom:18px; left:50%; transform:translateX(-50%);
    background:linear-gradient(180deg,#ffe08a,var(--gold-dark));
    color:#3a2400; border:none; border-radius:40px; padding:16px 40px;
    font-size:17px; font-weight:800; box-shadow:0 6px 0 #9e6f00, 0 10px 18px rgba(0,0,0,.4);
    cursor:pointer; z-index:15; letter-spacing:.5px;
    transition:transform .1s;
  }
  #castBtn:active{transform:translateX(-50%) translateY(4px); box-shadow:0 2px 0 #9e6f00, 0 4px 10px rgba(0,0,0,.4);}
  #castBtn.pulled{animation:pulse .5s infinite;}
  @keyframes pulse{ 0%,100%{transform:translateX(-50%) scale(1);} 50%{transform:translateX(-50%) scale(1.08);} }
  #castBtn:disabled{opacity:.5; cursor:default;}

  #comboBar{
    position:absolute; bottom:100px; left:50%; transform:translateX(-50%);
    width:84%; max-width:320px; height:14px; background:rgba(0,0,0,.35);
    border-radius:10px; overflow:hidden; display:none; border:1px solid rgba(255,255,255,.2);
  }
  #comboFill{height:100%; width:0%; background:linear-gradient(90deg,var(--gold),#fff3c0); transition:width .05s linear;}

  /* RHYTHM TIMING BAR */
  #rhythmWrap{
    position:absolute; bottom:130px; left:50%; transform:translateX(-50%);
    width:84%; max-width:320px; display:none; z-index:16;
  }
  #rhythmTrack{
    position:relative; width:100%; height:22px; background:rgba(0,0,0,.4);
    border-radius:12px; border:1px solid rgba(255,255,255,.25); overflow:hidden;
  }
  #rhythmZone{
    position:absolute; top:0; bottom:0; background:rgba(61,220,132,.45);
    border-left:2px solid var(--uncommon); border-right:2px solid var(--uncommon);
  }
  #rhythmCursor{
    position:absolute; top:-4px; bottom:-4px; width:5px; background:#fff;
    border-radius:3px; box-shadow:0 0 8px rgba(255,255,255,.8);
    left:0%;
  }
  #rhythmHint{
    text-align:center; font-size:11.5px; color:var(--text-dim); margin-top:5px; font-weight:700;
  }
  .missFlash{animation:missFlash .3s;}
  @keyframes missFlash{ 0%,100%{filter:none;} 50%{filter:brightness(2) hue-rotate(-40deg);} }

  /* FLOATING CATCH TOAST */
  .catchPopup{
    position:absolute; left:50%; top:40%; transform:translate(-50%,-50%) scale(.5);
    background:var(--panel); border:2px solid var(--gold); border-radius:18px;
    padding:20px 26px; text-align:center; z-index:100; opacity:0;
    box-shadow:0 10px 40px rgba(0,0,0,.6);
    animation:popIn .4s forwards;
  }
  @keyframes popIn{ to{ transform:translate(-50%,-50%) scale(1); opacity:1;} }
  .catchPopup .cfish{font-size:54px;}
  .catchPopup .cname{font-size:19px; font-weight:800; margin-top:4px;}
  .catchPopup .crarity{font-size:12px; font-weight:700; margin-top:2px; padding:3px 10px; border-radius:12px; display:inline-block;}
  .catchPopup .cweight{font-size:13px; color:var(--text-dim); margin-top:6px;}
  .catchPopup .ccoin{font-size:15px; color:var(--gold); font-weight:700; margin-top:4px;}
  .catchPopup .cclose{margin-top:14px; background:var(--gold); border:none; padding:9px 24px; border-radius:20px; font-weight:700; color:#3a2400;}

  /* BOTTOM NAV */
  #nav{
    display:flex; background:rgba(2,20,34,.92); border-top:1px solid rgba(255,255,255,.08);
    flex-shrink:0; position:relative; z-index:40; height:var(--nav-h);
  }
  .navBtn{
    flex:1; text-align:center; padding:9px 2px 8px; background:none; border:none; color:var(--text-dim);
    font-size:11px; font-weight:700; display:flex; flex-direction:column; align-items:center; gap:2px;
  }
  .navBtn .navIc{font-size:20px;}
  .navBtn.active{color:var(--gold);}

  /* PANELS (overlay screens) */
  .panel{
    position:absolute; top:0; left:0; right:0; bottom:var(--nav-h); background:var(--bg-deep); z-index:30;
    display:none; flex-direction:column; overflow:hidden;
  }
  .panel.show{display:flex;}
  .panelHeader{
    padding:14px 16px 10px; font-size:18px; font-weight:800; border-bottom:1px solid rgba(255,255,255,.08);
    display:flex; align-items:center; justify-content:space-between; flex-shrink:0; gap:10px;
  }
  .panelHeader .phTitle{flex:1; display:flex; align-items:center; gap:8px; flex-wrap:wrap;}
  .closeBtn{
    background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); color:var(--text);
    width:34px; height:34px; border-radius:50%; font-size:17px; font-weight:700;
    display:flex; align-items:center; justify-content:center; flex-shrink:0; line-height:1;
  }
  .closeBtn:active{background:rgba(255,255,255,.18);}
  .panelBody{flex:1; overflow-y:auto; padding:10px 12px 16px;}

  /* SHOP */
  .rodCard{
    background:var(--panel); border-radius:14px; padding:14px; margin-bottom:10px;
    border:2px solid rgba(255,255,255,.06); display:flex; gap:12px; align-items:center;
  }
  .rodCard.owned{border-color:var(--uncommon);}
  .rodCard.equipped{border-color:var(--gold); background:var(--panel-light);}
  .rodIcon{font-size:34px; width:44px; text-align:center;}
  .rodInfo{flex:1;}
  .rodInfo .rname{font-weight:800; font-size:14.5px;}
  .rodInfo .rdesc{font-size:12px; color:var(--text-dim); margin-top:2px;}
  .rodBtn{
    background:var(--gold); color:#3a2400; border:none; border-radius:10px; padding:9px 12px;
    font-weight:800; font-size:12.5px; white-space:nowrap;
  }
  .rodBtn.disabled{background:#3a4a5a; color:#7f95a8;}
  .rodBtn.equippedBtn{background:var(--uncommon); color:#04351f;}

  /* COLLECTION */
  .collectionHead{display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; padding:0 2px;}
  .collectionHead .cprog{font-size:13px; font-weight:700; color:var(--gold);}
  .fishGrid{display:grid; grid-template-columns:repeat(4,1fr); gap:8px;}
  .fishCell{
    background:var(--panel); border-radius:12px; padding:8px 4px; text-align:center;
    border:2px solid rgba(255,255,255,.05); position:relative;
  }
  .fishCell.locked{opacity:.35;}
  .fishCell .fic{font-size:26px;}
  .fishCell .fnm{font-size:9.5px; font-weight:700; margin-top:2px; line-height:1.2; min-height:22px;}
  .fishCell .fcount{position:absolute; top:2px; right:4px; font-size:9px; color:var(--gold); font-weight:800;}

  /* INVENTORY (sell) */
  .invItem{
    display:flex; align-items:center; gap:8px; flex-wrap:wrap; background:var(--panel); border-radius:12px;
    padding:10px 12px; margin-bottom:8px;
  }
  .invItem .fic{font-size:28px; width:36px; text-align:center; flex-shrink:0;}
  .invItem .iinfo{flex:1; min-width:0;}
  .invItem .iname{font-weight:700; font-size:13.5px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;}
  .invItem .iprice{font-size:11.5px; color:var(--gold); margin-top:1px;}
  .invItem .iqty{margin-left:auto; font-weight:800; color:var(--text-dim); font-size:13px; flex-shrink:0;}
  .invItem .sellOneBtn{
    background:var(--gold); color:#3a2400; border:none; padding:8px 12px; border-radius:10px;
    font-weight:800; font-size:11.5px; white-space:nowrap; margin-left:8px; flex-shrink:0;
  }
  .sellAllBtn{
    position:sticky; bottom:0; width:100%; background:linear-gradient(180deg,#ffe08a,var(--gold-dark));
    color:#3a2400; border:none; padding:14px; border-radius:14px; font-weight:800; font-size:15px;
    margin-top:8px; box-shadow:0 6px 0 #9e6f00;
  }

  /* CHAT */
  #chatMessages{flex:1; overflow-y:auto; padding:10px 12px; display:flex; flex-direction:column; gap:8px;}
  .msg{display:flex; gap:8px; align-items:flex-start; max-width:85%;}
  .msg .av{font-size:20px; flex-shrink:0; width:26px; height:26px; border-radius:50%; overflow:hidden; display:flex; align-items:center; justify-content:center;}
  .msg .bubble2{background:var(--panel); border-radius:14px 14px 14px 4px; padding:8px 12px; font-size:13.5px; word-break:break-word; overflow-wrap:anywhere;}
  .msg .name{font-size:11px; color:var(--text-dim); font-weight:700; margin-bottom:2px;}
  .msg .msgTime{font-size:10px; color:var(--text-dim); opacity:.65; margin-top:2px;}
  .msg.me .msgTime{text-align:right;}
  .msg.me{align-self:flex-end; flex-direction:row-reverse;}
  .msg.me .bubble2{background:var(--gold); color:#3a2400; border-radius:14px 14px 4px 14px;}
  .msg.sys{align-self:center; max-width:95%;}
  .msg.sys .bubble2{background:linear-gradient(90deg,rgba(255,211,92,.15),rgba(255,122,69,.15)); border:1px solid var(--gold); color:var(--gold); font-weight:700; text-align:center; font-size:12.5px;}
  #chatInputBar{display:flex; gap:8px; padding:10px; border-top:1px solid rgba(255,255,255,.08); flex-shrink:0;}
  #chatInputBar input{
    flex:1; background:var(--panel); border:1px solid rgba(255,255,255,.1); border-radius:20px;
    padding:11px 16px; color:var(--text); font-size:14px; outline:none;
  }
  #chatInputBar button{
    background:var(--gold); color:#3a2400; border:none; border-radius:50%; width:42px; height:42px;
    font-size:18px; flex-shrink:0;
  }

  .rarityTag{font-weight:800;}
  .r-common{color:var(--common);}
  .r-uncommon{color:var(--uncommon);}
  .r-rare{color:var(--rare);}
  .r-epic{color:var(--epic);}
  .r-mythic{color:var(--mythic);}
  .bg-common{background:rgba(185,199,211,.2); color:var(--common);}
  .bg-uncommon{background:rgba(61,220,132,.2); color:var(--uncommon);}
  .bg-rare{background:rgba(79,179,255,.2); color:var(--rare);}
  .bg-epic{background:rgba(193,99,255,.2); color:var(--epic);}
  .bg-mythic{background:rgba(255,122,69,.2); color:var(--mythic);}

  #toastWrap{position:absolute; top:56px; left:50%; transform:translateX(-50%); z-index:200; display:flex; flex-direction:column; gap:6px; align-items:center; pointer-events:none;}
  .toast{background:rgba(0,0,0,.75); color:#fff; padding:8px 16px; border-radius:20px; font-size:13px; font-weight:600; animation:toastIn .3s;}
  @keyframes toastIn{ from{opacity:0; transform:translateY(-10px);} to{opacity:1; transform:translateY(0);} }

  ::-webkit-scrollbar{width:5px;}
  ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.15); border-radius:10px;}
</style>
</head>
<body>
<div id="app">

  <!-- HEADER -->
  <div id="header">
    <button id="accountBtn">
      <span class="avatarIc" id="headerAvatarIc">👤</span>
      <span id="accountLabel">Đăng nhập</span>
    </button>
    <div style="display:flex; gap:6px;">
      <button id="bossRoomBtn" class="stat" style="cursor:pointer; background:linear-gradient(180deg,#ffe08a,var(--gold-dark)); color:#3a2400; font-weight:800;" title="Phòng Đại Ngư"><span class="ic">🐉</span></button>
      <button id="soundToggleBtn" class="stat" style="cursor:pointer;"><span id="soundIcon">🔊</span></button>
      <div class="stat"><span class="ic">💰</span><span id="coinDisplay">0</span></div>
      <div class="stat"><span class="ic">🐟</span><span id="fishCountDisplay">0/60</span></div>
    </div>
  </div>

  <!-- AUTH MODAL -->
  <div id="authModalWrap">
    <div id="authModal">
      <button id="authClose">✕</button>
      <h3 id="authTitle">Đăng nhập</h3>
      <div class="authSub" id="authSub">Đăng nhập để lưu tiến trình trên mọi thiết bị</div>
      <div id="authError"></div>
      <input type="text" id="authNickname" placeholder="Tên đăng nhập" autocomplete="username">
      <input type="password" id="authPassword" placeholder="Mật khẩu (từ 6 ký tự)" autocomplete="current-password">
      <button class="authBtn" id="authSubmitBtn">Đăng nhập</button>
      <div id="authSwitch">Chưa có tài khoản? <a id="authSwitchLink" href="#">Đăng ký ngay</a></div>
    </div>
  </div>

  <!-- ACCOUNT PANEL (when logged in, tap avatar) -->
  <div class="panel" id="panel-account">
    <div class="panelHeader">
      <span class="phTitle">👤 Tài Khoản</span>
      <button class="closeBtn" data-close>✕</button>
    </div>
    <div class="panelBody" id="accountPanelBody"></div>
  </div>

  <!-- GAME AREA -->
  <div id="gameArea">
    <div id="waterLine"></div>
    <div id="rodArea">
      <div id="rodIcon">🎣</div>
    </div>
    <div id="line"></div>
    <div id="hook">🪝</div>

    <div id="catchZone">
      <div id="fishSilhouette" style="display:none;">🐟</div>
      <div id="statusText">Nhấn "Thả câu" để bắt đầu!</div>
    </div>

