function renderShop(){
  const list = document.getElementById('shopList');
  list.innerHTML = '';
  RODS.forEach(rod=>{
    const owned = state.ownedRods.includes(rod.id);
    const equipped = state.equippedRod===rod.id;
    const card = document.createElement('div');
    card.className = 'rodCard' + (owned?' owned':'') + (equipped?' equipped':'');
    let btnHtml;
    if(equipped){
      btnHtml = `<button class="rodBtn equippedBtn">Đang dùng</button>`;
    } else if(owned){
      btnHtml = `<button class="rodBtn" data-equip="${rod.id}">Trang bị</button>`;
    } else {
      const afford = state.coins >= rod.price;
      btnHtml = `<button class="rodBtn ${afford?'':'disabled'}" data-buy="${rod.id}">${rod.price.toLocaleString('vi-VN')} 💰</button>`;
    }
    card.innerHTML = `
      <div class="rodIcon">${rod.icon}</div>
      <div class="rodInfo">
        <div class="rname">${rod.name}</div>
        <div class="rdesc">${rod.desc}</div>
      </div>
      ${btnHtml}
    `;
    list.appendChild(card);
  });

  list.querySelectorAll('[data-buy]').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const id = btn.getAttribute('data-buy');
      const rod = RODS.find(r=>r.id===id);
      if(state.coins >= rod.price){
        SoundEngine.sfx.buy();
        state.coins -= rod.price;
        state.ownedRods.push(id);
        state.equippedRod = id;
        saveState();
        updateHeader();
        renderShop();
        toast(`Đã mua và trang bị ${rod.name}!`);
        addSystemChatMsg(`🎉 Cần thủ #${state.playerId} vừa tậu ${rod.name}!`);
      } else {
        SoundEngine.sfx.error();
        toast('Không đủ xu 😢');
      }
    });
  });
  list.querySelectorAll('[data-equip]').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const id = btn.getAttribute('data-equip');
      SoundEngine.sfx.click();
      state.equippedRod = id;
      saveState();
      renderShop();
      toast('Đã trang bị cần câu!');
    });
  });
}

/* ============== COLLECTION ============== */
function renderCollection(){
  const grid = document.getElementById('fishGrid');
  grid.innerHTML='';
  const caughtCount = Object.keys(state.caughtIds).length;
  document.getElementById('collectionProg').textContent = caughtCount + '/60';

  FISH_LIST.forEach(fish=>{
    const caught = state.caughtIds[fish.id];
    const cell = document.createElement('div');
    cell.className = 'fishCell' + (caught?'':' locked');
    const r = RARITIES[fish.rarity];
    cell.innerHTML = `
      ${caught ? `<div class="fcount">x${caught.count}</div>` : ''}
      <div class="fic">${caught ? fish.icon : '❔'}</div>
      <div class="fnm r-${r.color}">${caught ? fish.name : '???'}</div>
    `;
    grid.appendChild(cell);
  });
}

/* ============== INVENTORY / SELL ============== */
function renderInventory(){
  const wrap = document.getElementById('invList');
  wrap.innerHTML='';
  const ids = Object.keys(state.inventory).filter(id=>state.inventory[id]>0);
  if(ids.length===0){
    wrap.innerHTML = `<div style="text-align:center; color:var(--text-dim); padding:40px 10px; font-size:14px;">Kho đồ trống. Hãy đi câu cá nào! 🎣</div>`;
    return;
  }
  let totalValue = 0;
  ids.forEach(id=>{
    const fish = FISH_LIST.find(f=>f.id==id);
    const qty = state.inventory[id];
    const r = RARITIES[fish.rarity];
    totalValue += fish.price*qty;
    const item = document.createElement('div');
    item.className='invItem';
    item.innerHTML = `
      <div class="fic">${fish.icon}</div>
      <div class="iinfo">
        <div class="iname">${fish.name} <span class="r-${r.color}" style="font-size:10.5px;">(${r.label})</span></div>
        <div class="iprice">${fish.price.toLocaleString('vi-VN')} xu / con</div>
      </div>
      <div class="iqty">x${qty}</div>
      <button class="sellOneBtn" data-sell-id="${id}">Bán (${(fish.price*qty).toLocaleString('vi-VN')} 💰)</button>
    `;
    wrap.appendChild(item);
  });
  wrap.querySelectorAll('[data-sell-id]').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const id = btn.getAttribute('data-sell-id');
      const fish = FISH_LIST.find(f=>f.id==id);
      const qty = state.inventory[id]||0;
      if(qty<=0) return;
      SoundEngine.sfx.sell();
      const b = rodBonus();
      let value = fish.price*qty;
      if(b.sellBonus) value = Math.round(value*(1+b.sellBonus));
      state.coins += value;
      delete state.inventory[id];
      saveState();
      updateHeader();
      renderInventory();
      toast(`Đã bán ${fish.name}, nhận ${value.toLocaleString('vi-VN')} xu!`);
    });
  });
  const sellBtn = document.createElement('button');
  sellBtn.className='sellAllBtn';
  sellBtn.textContent = `💰 Bán tất cả (nhận ${totalValue.toLocaleString('vi-VN')} xu)`;
  sellBtn.addEventListener('click', ()=>{
    SoundEngine.sfx.sell();
    const b = rodBonus();
    let value = totalValue;
    if(b.sellBonus) value = Math.round(value*(1+b.sellBonus));
    state.coins += value;
    state.inventory = {};
    saveState();
    updateHeader();
    renderInventory();
    toast(`Đã bán cá, nhận ${value.toLocaleString('vi-VN')} xu!`);
  });
  wrap.appendChild(sellBtn);
}

/* ============== CHAT (real, via Firebase Realtime Database) ============== */
const chatMessages = document.getElementById('chatMessages');
const CHAT_PATH = 'globalChat';
const MAX_CHAT_HISTORY = 100;

const CHAT_TTL_MS = 5 * 60 * 60 * 1000; // tin nhắn tự xoá sau 5 giờ

function formatChatTime(ts){
  if(!ts) return '';
  const d = new Date(ts);
  const hh = String(d.getHours()).padStart(2,'0');
  const mm = String(d.getMinutes()).padStart(2,'0');
  return `${hh}:${mm}`;
}

function addChatBubble(name, text, isMe=false, isSys=false, avatar='', ts=null, msgKey=''){
  const div = document.createElement('div');
  div.className = 'msg' + (isMe?' me':'') + (isSys?' sys':'');
  if(msgKey) div.dataset.msgKey = msgKey;
  const timeLabel = ts ? `<div class="msgTime">${formatChatTime(ts)}</div>` : '';
  if(isSys){
    div.innerHTML = `<div class="bubble2">${text}</div>${timeLabel}`;
  } else {
    const av = avatarInnerHtml(avatar || (isMe ? '🙂' : '🎣'));
    div.innerHTML = `
      <div class="av">${av}</div>
      <div>
        ${!isMe?`<div class="name">${name}</div>`:''}
        <div class="bubble2">${text}</div>
        ${timeLabel}
      </div>
    `;
  }
  chatMessages.appendChild(div);
  chatMessages.scrollTop = chatMessages.scrollHeight;
  while(chatMessages.children.length > 80) chatMessages.removeChild(chatMessages.firstChild);
}

function addSystemChatMsg(text, ts=null){
  addChatBubble('', `📢 ${text}`, false, true, '', ts);
}

function broadcastFlex(fish, weight){
  if(!currentUser) return; // only broadcast for real logged-in players
  const r = RARITIES[fish.rarity];
  const nick = state.nickname || currentUser.displayName || 'Cần thủ';
  sendChatMessage(`📢 Chúc mừng cần thủ ${nick} vừa câu được ${fish.name} (${r.label} - nặng ${weight}kg) tại Hồ Vô Cực!`, true);
}

function sendChatMessage(text, isSystem=false){
  if(!currentUser){
    toast('Vui lòng đăng nhập để chat!');
    return;
  }
  const nick = state.nickname || currentUser.displayName || 'Cần thủ';
  const msg = {
    uid: currentUser.uid,
    name: nick,
    avatar: state.avatar || '👤',
    text: text,
    sys: !!isSystem,
    ts: firebase.database.ServerValue.TIMESTAMP
  };
  const chatRef = db.ref(CHAT_PATH).push();
  chatRef.set(msg).catch(()=>{ toast('Gửi tin nhắn thất bại, thử lại nhé.'); });
  if(!isSystem) SoundEngine.sfx.msg();
}

function attachRealtimeChat(){
  if(chatListenerAttached) return;
  chatListenerAttached = true;
  chatMessages.innerHTML='';
  addSystemChatMsg('Chào mừng đến với Fishing World! Chỉ tin nhắn từ người chơi thật mới hiển thị ở đây 🎣');
  db.ref(CHAT_PATH).limitToLast(MAX_CHAT_HISTORY).on('child_added', (snap)=>{
    const m = snap.val();
    if(!m || !m.text) return;
    const age = m.ts ? (Date.now() - m.ts) : 0;
    if(m.ts && age > CHAT_TTL_MS){
      // tin nhắn đã quá 5 giờ, xoá khỏi Firebase và không hiển thị
      snap.ref.remove().catch(()=>{});
      return;
    }
    if(m.sys){
      addSystemChatMsg(escapeHtml(m.text.replace(/^📢\s*/,'')), m.ts);
    } else {
      const isMe = currentUser && m.uid === currentUser.uid;
      addChatBubble(escapeHtml(m.name||'Cần thủ'), escapeHtml(m.text), isMe, false, m.avatar||'', m.ts, snap.key);
    }
    // hẹn giờ tự xoá khỏi Firebase đúng lúc đủ 5 giờ (nếu client vẫn đang mở)
    if(m.ts){
      const remaining = CHAT_TTL_MS - age;
      if(remaining > 0 && remaining < 2147483647){
        setTimeout(()=>{ snap.ref.remove().catch(()=>{}); }, remaining);
      }
    }
  });
  db.ref(CHAT_PATH).on('child_removed', (snap)=>{
    const el = chatMessages.querySelector(`[data-msg-key="${snap.key}"]`);
    if(el) el.remove();
  });
}

document.getElementById('chatSendBtn').addEventListener('click', sendChat);
document.getElementById('chatInput').addEventListener('keydown', (e)=>{
  if(e.key==='Enter') sendChat();
});
function sendChat(){
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if(!text) return;
  if(!currentUser){
    toast('Vui lòng đăng nhập để chat với các cần thủ khác!');
    openAuthModal('login');
    return;
  }
  if(/^data:image\//i.test(text) || /^[A-Za-z0-9+/=]{60,}$/.test(text)){
    toast('Tin nhắn không hợp lệ (có thể là dữ liệu ảnh), vui lòng nhập chữ thường.');
    return;
  }
  // Nếu có 1 "từ" quá dài (không dấu cách) sẽ làm vỡ layout chat -> chặn luôn
  const longestWord = text.split(/\s+/).reduce((a,w)=>Math.max(a,w.length),0);
  if(longestWord > 60){
    toast('Tin nhắn có đoạn quá dài, vui lòng rút gọn.');
    return;
  }
  sendChatMessage(text, false);
  input.value='';
}
function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ============== NAV ============== */
const navBtns = document.querySelectorAll('.navBtn');
function goToGameTab(){
  navBtns.forEach(b=>b.classList.remove('active'));
  document.querySelector('.navBtn[data-panel="game"]').classList.add('active');
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('show'));
}
navBtns.forEach(btn=>{
  btn.addEventListener('click', ()=>{
    SoundEngine.unlock();
    SoundEngine.sfx.open();
    navBtns.forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const target = btn.getAttribute('data-panel');
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('show'));
    if(target!=='game'){
      document.getElementById('panel-'+target).classList.add('show');
      if(target==='shop') renderShop();
      if(target==='collection') renderCollection();
      if(target==='inventory') renderInventory();
    }
  });
});

/* ============== CLOSE BUTTONS ============== */
document.querySelectorAll('.closeBtn[data-close]').forEach(btn=>{
  btn.addEventListener('click', ()=>{ SoundEngine.sfx.close(); goToGameTab(); });
});

/* ============== PHÒNG ĐẠI NGƯ ============== */
const bossRoomBtn = document.getElementById('bossRoomBtn');
if(bossRoomBtn){
  bossRoomBtn.addEventListener('click', ()=>{
    SoundEngine.unlock();
    SoundEngine.sfx.click();
    window.location.href = 'daingu.html';
  });
}

/* ============== INIT ============== */
updateHeader();
resetVisual();

})();
