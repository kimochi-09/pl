/* ============== FISHING LOGIC ============== */
let fishingState = "idle"; // idle -> waiting -> biting -> reeling
let waitTimer=null, biteTimeout=null;
const rodBonus = ()=> RODS.find(r=>r.id===state.equippedRod).bonus;

function getRodSpeedMultiplier(){
  const b = rodBonus();
  return 1 - (b.speed||0);
}

function rollFish(){
  const b = rodBonus();
  // base weights
  let weights = {common:50, uncommon:30, rare:14, epic:5, mythic:1};
  if(b.uncommon) weights.uncommon += b.uncommon;
  if(b.rareUp){ weights.rare += b.rareUp; weights.epic += b.rareUp*0.5; }
  if(b.epic){ weights.epic += b.epic; }
  if(b.mythicEpic){ weights.mythic += b.mythicEpic*0.4; weights.epic += b.mythicEpic; }
  // normalize pick
  const total = Object.values(weights).reduce((a,c)=>a+c,0);
  let r = Math.random()*total;
  let rarity = 'common';
  for(const key of ['common','uncommon','rare','epic','mythic']){
    if(r < weights[key]){ rarity=key; break; }
    r -= weights[key];
  }
  const pool = FISH_LIST.filter(f=>f.rarity===rarity);
  const fish = pool[Math.floor(Math.random()*pool.length)];
  return fish;
}

