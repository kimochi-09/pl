<script>
(function(){
"use strict";

/* ============== SOUND ENGINE (nhạc nền + hiệu ứng, tạo bằng Web Audio API, không cần file mp3) ============== */
const SoundEngine = (function(){
  let ctx = null;
  let masterGain = null;
  let musicGain = null;
  let sfxGain = null;
  let musicNodes = [];
  let musicTimer = null;
  let musicOn = true;
  let unlocked = false;

  function ensureCtx(){
    if(!ctx){
      ctx = new (window.AudioContext || window.webkitAudioContext)();
      masterGain = ctx.createGain(); masterGain.gain.value = 1; masterGain.connect(ctx.destination);
      musicGain = ctx.createGain(); musicGain.gain.value = 0.16; musicGain.connect(masterGain);
      sfxGain = ctx.createGain(); sfxGain.gain.value = 0.5; sfxGain.connect(masterGain);
    }
    if(ctx.state === 'suspended') ctx.resume();
    return ctx;
  }

  function unlock(){
    if(unlocked) return;
    unlocked = true;
    ensureCtx();
    if(musicOn) startMusic();
  }
  ['pointerdown','keydown','touchstart'].forEach(ev=>{
    window.addEventListener(ev, unlock, {once:true, passive:true});
  });

  function tone(freq, startTime, dur, {type='sine', gain=0.5, attack=0.008, release=0.08, freqEnd=null, detune=0} = {}){
    const c = ensureCtx();
    const osc = c.createOscillator();
    osc.type = type;
    osc.frequency.setValueAtTime(freq, startTime);
    if(freqEnd) osc.frequency.exponentialRampToValueAtTime(Math.max(freqEnd,1), startTime+dur);
    if(detune) osc.detune.value = detune;
    const g = c.createGain();
    g.gain.setValueAtTime(0, startTime);
    g.gain.linearRampToValueAtTime(gain, startTime+attack);
    g.gain.exponentialRampToValueAtTime(0.001, startTime+dur+release);
    osc.connect(g); g.connect(sfxGain);
    osc.start(startTime);
    osc.stop(startTime+dur+release+0.05);
  }

  function noiseBurst(startTime, dur, {gain=0.3, filterFreq=2000, type='highpass'} = {}){
    const c = ensureCtx();
    const bufSize = Math.max(1, Math.floor(c.sampleRate*dur));
    const buf = c.createBuffer(1, bufSize, c.sampleRate);
    const data = buf.getChannelData(0);
    for(let i=0;i<bufSize;i++) data[i] = (Math.random()*2-1) * (1 - i/bufSize);
    const src = c.createBufferSource();
    src.buffer = buf;
    const filt = c.createBiquadFilter();
    filt.type = type; filt.frequency.value = filterFreq;
    const g = c.createGain();
    g.gain.setValueAtTime(gain, startTime);
    g.gain.exponentialRampToValueAtTime(0.001, startTime+dur);
    src.connect(filt); filt.connect(g); g.connect(sfxGain);
    src.start(startTime); src.stop(startTime+dur+0.05);
  }

  const SFX = {
    click(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(520, t, 0.05, {type:'triangle', gain:0.25}); },
    cast(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(280, t, 0.28, {type:'sine', gain:0.35, freqEnd:110}); noiseBurst(t, 0.15, {gain:0.12, filterFreq:3500}); },
    bite(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(880, t, 0.09, {type:'square', gain:0.22}); tone(1180, t+0.09, 0.09, {type:'square', gain:0.22}); },
    hit(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(660, t, 0.08, {type:'triangle', gain:0.3}); tone(990, t+0.05, 0.1, {type:'triangle', gain:0.25}); },
    miss(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(220, t, 0.18, {type:'sawtooth', gain:0.22, freqEnd:120}); },
    escape(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(400, t, 0.35, {type:'sawtooth', gain:0.25, freqEnd:80}); noiseBurst(t+0.05, 0.25, {gain:0.15, filterFreq:1200}); },
    catchFish(rarity){
      if(!unlocked) return;
      const t = ensureCtx().currentTime;
      const scales = {
        common:   [523.25, 659.25, 783.99],
        uncommon: [523.25, 659.25, 783.99, 1046.5],
        rare:     [587.33, 739.99, 880, 1174.7],
        epic:     [659.25, 830.61, 987.77, 1318.5, 1567.98],
        mythic:   [659.25, 830.61, 987.77, 1318.5, 1567.98, 1975.53]
      };
      const notes = scales[rarity] || scales.common;
      notes.forEach((f,i)=> tone(f, t + i*0.09, 0.22, {type:'triangle', gain:0.3, release:0.15}));
      if(rarity==='epic' || rarity==='mythic'){
        notes.forEach((f,i)=> tone(f*2, t + i*0.09 + 0.02, 0.18, {type:'sine', gain:0.12}));
      }
    },
    buy(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(440,t,0.07,{type:'square',gain:0.25}); tone(660,t+0.07,0.12,{type:'square',gain:0.25}); },
    sell(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(700,t,0.06,{type:'sine',gain:0.28}); tone(500,t+0.06,0.09,{type:'sine',gain:0.22}); },
    error(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(180, t, 0.15, {type:'square', gain:0.2}); },
    open(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(392, t, 0.06, {type:'sine', gain:0.2}); tone(523.25, t+0.06, 0.08, {type:'sine', gain:0.2}); },
    close(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(523.25, t, 0.06, {type:'sine', gain:0.18}); tone(392, t+0.05, 0.08, {type:'sine', gain:0.18}); },
    msg(){ if(!unlocked) return; const t=ensureCtx().currentTime; tone(700, t, 0.05, {type:'sine', gain:0.15}); },
    login(){ if(!unlocked) return; const t=ensureCtx().currentTime; [523.25,659.25,783.99,1046.5].forEach((f,i)=>tone(f,t+i*0.08,0.16,{type:'triangle',gain:0.28})); }
  };

  /* Nhạc nền: giai điệu lặp nhẹ nhàng, êm dịu kiểu biển cả, tạo bằng oscillator theo vòng lặp hợp âm */
  const MUSIC_SCALE = [261.63, 293.66, 329.63, 392.00, 440.00, 523.25]; // C pentatonic-ish, êm dịu
  const CHORD_PROG = [
    [261.63, 329.63, 392.00],   // C
    [220.00, 261.63, 329.63],   // Am
    [174.61, 220.00, 261.63],   // F
    [196.00, 246.94, 293.66]    // G
  ];
  let musicStep = 0;
  let chordIdx = 0;

  function scheduleMusicBar(startTime){
    const c = ensureCtx();
    const chord = CHORD_PROG[chordIdx % CHORD_PROG.length];
    chordIdx++;
    const barDur = 4.0;
    // pad chord (dịu, nền)
    chord.forEach(f=>{
      const osc = c.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = f;
      const g = c.createGain();
      g.gain.setValueAtTime(0, startTime);
      g.gain.linearRampToValueAtTime(0.5, startTime+0.6);
      g.gain.linearRampToValueAtTime(0.35, startTime+barDur-0.6);
      g.gain.linearRampToValueAtTime(0, startTime+barDur);
      osc.connect(g); g.connect(musicGain);
      osc.start(startTime); osc.stop(startTime+barDur+0.05);
      musicNodes.push(osc);
    });
    // giai điệu lơ lửng, ngẫu nhiên nhẹ nhàng theo pentatonic, mô phỏng tiếng chuông nước
    const noteCount = 4 + Math.floor(Math.random()*3);
    for(let i=0;i<noteCount;i++){
      const t = startTime + (i/noteCount)*barDur + Math.random()*0.15;
      const note = MUSIC_SCALE[Math.floor(Math.random()*MUSIC_SCALE.length)] * (Math.random()<0.3 ? 2 : 1);
      const osc = c.createOscillator();
      osc.type = 'sine';
      osc.frequency.value = note;
      const g = c.createGain();
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.22, t+0.05);
      g.gain.exponentialRampToValueAtTime(0.001, t+1.1);
      osc.connect(g); g.connect(musicGain);
      osc.start(t); osc.stop(t+1.2);
      musicNodes.push(osc);
    }
  }

  function startMusic(){
    if(!unlocked) return;
    stopMusic();
    const c = ensureCtx();
    let nextBarTime = c.currentTime + 0.1;
    scheduleMusicBar(nextBarTime);
    musicTimer = setInterval(()=>{
      nextBarTime += 4.0;
      scheduleMusicBar(nextBarTime);
    }, 4000);
  }
  function stopMusic(){
    if(musicTimer){ clearInterval(musicTimer); musicTimer=null; }
    musicNodes.forEach(n=>{ try{ n.stop(); }catch(e){} });
    musicNodes = [];
  }

  function setMusicOn(on){
    musicOn = on;
    if(on){ if(unlocked) startMusic(); }
    else { stopMusic(); }
  }
  function isMusicOn(){ return musicOn; }

  return { sfx: SFX, unlock, setMusicOn, isMusicOn };
})();


