  // Higher rarity fish require more successful hits & move faster
  const hitsByRarity = {common:2, uncommon:3, rare:4, epic:5, mythic:6};
  requiredHits = hitsByRarity[pendingFish.rarity] || 3;
  currentHits = 0;
  missCount = 0;

  statusText.textContent = `🎣 ${pendingFish.icon} ${pendingFish.name} đã cắn câu! (0/${requiredHits})`;

  startRhythmLoop();

  // if not reeled within time, fish escapes (unless noMiss rod)
  const b = rodBonus();
  const escapeTime = 9000;
  biteTimeout = setTimeout(()=>{
    if(fishingState==='biting' && !b.noMiss){
      fishEscape();
    } else if(fishingState==='biting' && b.noMiss){
      landFish();
    }
  }, escapeTime);
}

/* ---- Rhythm timing mechanic ---- */
let rhythmAnim = null;
let rhythmPos = 0;
let rhythmDir = 1;
let rhythmSpeed = 1.6;   // % per frame tick
let zoneStart = 40, zoneWidth = 20; // percentages

function randomizeZone(){
  const b = rodBonus();
  // easier rods (rareUp/epic/mythicEpic bonuses) get slightly wider zone
  let width = 18;
  if(b.rareUp) width += 2;
  if(b.epic) width += 3;
  if(b.mythicEpic) width += 4;
  zoneWidth = Math.min(width, 34);
  zoneStart = Math.random()*(100-zoneWidth);
  rhythmZone.style.left = zoneStart+'%';
  rhythmZone.style.width = zoneWidth+'%';
}

function startRhythmLoop(){
  randomizeZone();
  rhythmPos = 0;
  rhythmDir = 1;
  rhythmWrap.style.display='block';
  // speed scales with rarity (harder fish move faster) and rod speed bonus
  const rarityMult = {common:1, uncommon:1.15, rare:1.35, epic:1.55, mythic:1.8}[pendingFish.rarity] || 1;
  rhythmSpeed = (1.4 + Math.random()*0.4) * rarityMult;

  function tick(){
    rhythmPos += rhythmSpeed * rhythmDir;
    if(rhythmPos >= 100){ rhythmPos = 100; rhythmDir = -1; }
    if(rhythmPos <= 0){ rhythmPos = 0; rhythmDir = 1; }
    rhythmCursor.style.left = rhythmPos+'%';
    rhythmAnim = requestAnimationFrame(tick);
  }
  rhythmAnim = requestAnimationFrame(tick);
}

function stopRhythmLoop(){
  if(rhythmAnim){ cancelAnimationFrame(rhythmAnim); rhythmAnim=null; }
}

function tryReelHit(){
  if(fishingState !== 'biting') return;
  const b = rodBonus();
  const inZone = b.noMiss ? true : (rhythmPos >= zoneStart && rhythmPos <= zoneStart+zoneWidth);

  if(inZone){
    SoundEngine.sfx.hit();
    currentHits++;
    comboFill.style.width = Math.round((currentHits/requiredHits)*100)+'%';
    statusText.textContent = `✅ Đúng nhịp! (${currentHits}/${requiredHits})`;
    if(currentHits >= requiredHits){
      landFish();
      return;
    }
    randomizeZone(); // new zone position for next hit, keeps challenge going
  } else {
    // Miss! penalize progress and flash red, risk losing the fish
    SoundEngine.sfx.miss();
    gameArea.classList.add('missFlash');
    setTimeout(()=>gameArea.classList.remove('missFlash'), 300);
    currentHits = Math.max(0, currentHits - 1);
    comboFill.style.width = Math.round((currentHits/requiredHits)*100)+'%';
    statusText.textContent = `❌ Nhấn lệch nhịp! Cẩn thận, cá sắp sổng (${currentHits}/${requiredHits})`;
    missCount++;
    if(missCount >= maxMisses){
      fishEscape();
    }
  }
}
let missCount = 0;
const maxMisses = 3;

function fishEscape(){
  SoundEngine.sfx.escape();
  clearTimeout(biteTimeout);
  stopRhythmLoop();
  fishingState='idle';
  currentHits=0; missCount=0;
  statusText.textContent='😭 Cá đã sổng mất vì nhấn lệch nhịp! Thử lại nhé.';
  castBtn.textContent='🎣 THẢ CÂU';
  resetVisual();
}

function landFish(){
  clearTimeout(biteTimeout);
  stopRhythmLoop();
  fishingState='idle';
  currentHits=0; missCount=0;
  const fish = pendingFish;
  pendingFish=null;
  castBtn.textContent='🎣 THẢ CÂU';
  resetVisual();
  statusText.textContent='Nhấn "Thả câu" để tiếp tục!';

  // record
  const weight = generateWeight(fish.rarity);
  state.inventory[fish.id] = (state.inventory[fish.id]||0)+1;
  if(!state.caughtIds[fish.id]) state.caughtIds[fish.id] = {count:0, maxWeight:0};
  state.caughtIds[fish.id].count++;
  if(weight > state.caughtIds[fish.id].maxWeight) state.caughtIds[fish.id].maxWeight = weight;
  saveState();
  updateHeader();
  SoundEngine.sfx.catchFish(fish.rarity);
  showCatchPopup(fish, weight);

  if(fish.rarity==='epic' || fish.rarity==='mythic'){
    broadcastFlex(fish, weight);
  }
}

function generateWeight(rarity){
  const ranges = {common:[0.2,3], uncommon:[1,8], rare:[5,40], epic:[30,300], mythic:[80,900]};
  const [lo,hi] = ranges[rarity];
  return Math.round((lo + Math.random()*(hi-lo))*10)/10;
}

function showCatchPopup(fish, weight){
  const r = RARITIES[fish.rarity];
  const pop = document.createElement('div');
